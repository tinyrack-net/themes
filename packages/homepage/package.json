{
  "name": "@tinyrack/homepage",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-worktree.ts",
    "dev:app": "cross-env NODE_OPTIONS=--conditions=@tinyrack/source react-router dev",
    "build": "react-router build",
    "preview": "vite preview",
    "typegen": "react-router typegen",
    "check:types": "pnpm typegen && tsc --noEmit",
    "generate:app-icons": "node scripts/generate-app-icons.mjs",
    "check:app-icons": "node scripts/generate-app-icons.mjs --check",
    "capture": "node --experimental-strip-types scripts/capture.ts",
    "check": "pnpm check:types && pnpm check:app-icons",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run --project unit",
    "test:e2e": "node scripts/test-e2e.ts",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@tinyrack/docs": "workspace:*",
    "@react-router/node": "8.2.0",
    "@tinyrack/ui": "workspace:*",
    "isbot": "5.2.0",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0",
    "shiki": "4.3.1"
  },
  "devDependencies": {
    "@react-router/dev": "8.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "cross-env": "10.1.0",
    "playwright": "1.61.1",
    "sharp": "0.34.5",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "wrangler": "4.107.0"
  }
}
