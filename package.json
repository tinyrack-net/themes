{
  "name": "tinyrack-ui-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "biome": "biome check .",
    "dev": "pnpm --filter @tinyrack/homepage dev",
    "build": "pnpm --filter @tinyrack/ui build && pnpm --filter @tinyrack/homepage build",
    "verify": "pnpm biome && pnpm --filter @tinyrack/ui verify && pnpm --filter @tinyrack/homepage verify",
    "verify:release": "pnpm verify",
    "test:unit": "pnpm --filter @tinyrack/ui test:unit",
    "test:component": "pnpm --filter @tinyrack/ui test:component",
    "test:coverage": "pnpm --filter @tinyrack/ui test:coverage",
    "test:dist": "pnpm --filter @tinyrack/ui test:dist",
    "docs:build": "pnpm --filter @tinyrack/homepage build",
    "docs:audit": "pnpm --filter @tinyrack/homepage test:audit",
    "docs:capture": "pnpm --filter @tinyrack/homepage capture",
    "docs:deploy": "pnpm --filter @tinyrack/homepage run deploy",
    "docs:deploy:dry-run": "pnpm --filter @tinyrack/homepage deploy:dry-run",
    "test:docs": "pnpm docs:build && pnpm docs:audit",
    "pack:ui": "pnpm --dir packages/ui pack --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2"
  }
}
