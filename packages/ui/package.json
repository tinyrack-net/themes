{
  "name": "@tinyrack/ui",
  "version": "0.8.0",
  "description": "React-only Tinyrack UI components and design tokens.",
  "keywords": [
    "design-system",
    "react",
    "tailwindcss",
    "theme",
    "tokens",
    "typescript",
    "ui"
  ],
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "author": "Tinyrack",
  "homepage": "https://www.npmjs.com/package/@tinyrack/ui",
  "bugs": {
    "url": "https://github.com/tinyrack-net/design/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyrack-net/design.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run --project unit",
    "test:e2e": "pnpm build && vitest run --mode component-coverage --project browser --coverage && vitest run --mode component-firefox --project browser",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.3.0 <5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "playwright": "^1.61.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwindcss": "^4.3.3",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./components/*": {
      "@tinyrack/source": "./src/components/*/index.tsx",
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./components/*.css": {
      "@tinyrack/source": "./src/components/*/*.css",
      "default": "./dist/components/*/*.css"
    },
    "./components/*/react": null,
    "./components/*/dom": null,
    "./components/overlay": null,
    "./providers/*": {
      "@tinyrack/source": "./src/providers/*/index.tsx",
      "types": "./dist/providers/*/index.d.ts",
      "import": "./dist/providers/*/index.js"
    },
    "./core": {
      "@tinyrack/source": "./src/core/index.ts",
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./core.css": {
      "@tinyrack/source": "./src/core/core.css",
      "default": "./dist/core.css"
    },
    "./mdx": {
      "@tinyrack/source": "./src/mdx/index.tsx",
      "types": "./dist/mdx/index.d.ts",
      "import": "./dist/mdx/index.js"
    },
    "./mdx.css": {
      "@tinyrack/source": "./src/mdx/mdx.css",
      "default": "./dist/mdx.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./components/*": {
        "types": "./dist/components/*/index.d.ts",
        "import": "./dist/components/*/index.js"
      },
      "./components/*.css": "./dist/components/*/*.css",
      "./components/*/react": null,
      "./components/*/dom": null,
      "./components/overlay": null,
      "./providers/*": {
        "types": "./dist/providers/*/index.d.ts",
        "import": "./dist/providers/*/index.js"
      },
      "./core": {
        "types": "./dist/core/index.d.ts",
        "import": "./dist/core/index.js"
      },
      "./core.css": "./dist/core.css",
      "./mdx": {
        "types": "./dist/mdx/index.d.ts",
        "import": "./dist/mdx/index.js"
      },
      "./mdx.css": "./dist/mdx.css",
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "lucide-react": "1.25.0",
    "shiki": "4.3.1"
  }
}
