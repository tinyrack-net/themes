{
  "name": "@tinyrack/homepage",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "node scripts/build.ts && node scripts/audit-build-assets.ts",
    "preview:search": "pnpm build && pagefind --serve",
    "typegen": "react-router typegen",
    "check:types": "react-router typegen && tsc --noEmit",
    "check:structure": "vitest run tests/structure.test.ts",
    "test:audit": "vitest run",
    "capture": "node --experimental-strip-types scripts/capture.ts",
    "verify": "pnpm check:types && pnpm check:structure && pnpm build && pnpm test:audit",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "5.2.8",
    "@fontsource/ibm-plex-sans-jp": "5.2.8",
    "@fontsource/ibm-plex-sans-kr": "5.2.8",
    "@mdx-js/react": "3.1.1",
    "@react-router/node": "8.2.0",
    "@shikijs/langs": "4.3.1",
    "@shikijs/themes": "4.3.1",
    "@tinyrack/ui": "workspace:*",
    "isbot": "5.2.0",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0",
    "shiki": "4.3.1"
  },
  "devDependencies": {
    "@mdx-js/rollup": "3.1.1",
    "@react-router/dev": "8.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "mdast-util-to-string": "4.0.0",
    "pagefind": "1.5.2",
    "playwright": "1.61.1",
    "remark-gfm": "4.0.1",
    "remark-mdx": "3.1.1",
    "remark-parse": "11.0.0",
    "sharp": "0.34.5",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "unified": "11.0.5",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "wrangler": "4.107.0"
  }
}
