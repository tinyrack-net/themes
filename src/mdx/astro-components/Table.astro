---
import type { TableProps } from './props.js';
import { mergeClassNames } from '../shared.js';

interface Props extends TableProps {}

const {
  class: classAttribute,
  className,
  'data-density': dataDensity,
  ...tableProps
} = Astro.props;
---

<div class="tr-table-container tr-mdx-table-container">
  <table
    {...tableProps}
    class={mergeClassNames('tr-table tr-mdx-table', classAttribute, className)}
    data-density={dataDensity ?? 'normal'}
  >
    <slot />
  </table>
</div>
