{
  "name": "@tinyrack/themes",
  "version": "0.20.0",
  "description": "Design-system tokens and theme adapters for Mantine, daisyUI, Tailwind CSS, and Astro Starlight.",
  "keywords": [
    "astro",
    "astro-starlight",
    "daisyui",
    "design-system",
    "mantine",
    "starlight",
    "storybook",
    "tailwindcss",
    "theme",
    "tokens",
    "typescript",
    "ui"
  ],
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "author": "Tinyrack",
  "homepage": "https://www.npmjs.com/package/@tinyrack/themes",
  "bugs": {
    "url": "https://github.com/tinyrack-net/themes/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tinyrack-net/themes.git"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "dev": "pnpm generate:stories && pnpm generate:css && storybook dev -p 6006 --host 127.0.0.1 --no-open",
    "build": "pnpm build:css",
    "build:types": "tsc -p tsconfig.build.json",
    "generate:css": "pnpm build:types && node scripts/copy-css.ts --src-only",
    "build:css": "pnpm build:types && node scripts/copy-css.ts",
    "check:css": "pnpm build:types && node scripts/copy-css.ts --check",
    "check:types": "pnpm generate:stories && tsc -p tsconfig.json --noEmit && pnpm check:tests",
    "check:tests": "tsc -p tsconfig.test.json --noEmit",
    "check:scripts": "tsc -p tsconfig.scripts.json",
    "verify": "pnpm biome && pnpm check:types && pnpm check:scripts && pnpm check:css && pnpm check:stories && pnpm test && pnpm build && pnpm test:dist && pnpm test:astro-fixture:built",
    "verify:release": "pnpm verify && pnpm test:storybook",
    "test": "pnpm test:unit && pnpm test:component",
    "test:unit": "vitest run --project unit",
    "test:component": "pnpm generate:css && vitest run --project browser",
    "test:coverage": "vitest run --project unit --project browser --coverage",
    "test:dist": "node scripts/test-dist-package.ts",
    "storybook": "pnpm generate:stories && pnpm generate:css && storybook dev -p 6006 --host 127.0.0.1 --no-open",
    "storybook:build": "pnpm generate:stories && pnpm generate:css && storybook build",
    "storybook:audit": "node scripts/audit-storybook-scenarios.ts",
    "biome": "biome check .",
    "biome:fix": "biome check --write .",
    "test:astro-fixture": "pnpm build && pnpm test:astro-fixture:built",
    "test:astro-fixture:built": "pnpm --dir tests/fixtures/astro-starlight-site install --frozen-lockfile && pnpm --dir tests/fixtures/astro-starlight-site build",
    "test:storybook": "pnpm storybook:build && pnpm storybook:audit",
    "test:showcase": "pnpm generate:stories && pnpm generate:css && vitest run --project unit src/showcase/showcase-registry.test.ts && vitest run --project browser src/showcase/showcase-render.browser.test.tsx",
    "generate:stories": "node scripts/generate-showcase-stories.ts",
    "check:stories": "pnpm generate:stories && node scripts/generate-showcase-stories.ts --check",
    "deploy:storybook": "wrangler deploy",
    "deploy:storybook:dry-run": "wrangler deploy --dry-run"
  },
  "peerDependencies": {
    "@astrojs/starlight": ">=0.40.0",
    "@mantine/core": ">=9.0.0",
    "astro": ">=6.0.0",
    "daisyui": ">=5.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.41.2",
    "@biomejs/biome": "^2.5.2",
    "@mantine/core": "^9.4.1",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-docs": "latest",
    "@storybook/react-vite": "latest",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "astro": "^7.0.6",
    "daisyui": "^5.6.10",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "latest",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0",
    "wrangler": "4.107.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./tailwind.css": "./dist/tailwind/theme.css",
    "./tailwind/daisyui.css": "./dist/tailwind/daisyui.css",
    "./tailwind/mantine.css": "./dist/tailwind/mantine.css",
    "./mantine": {
      "types": "./dist/mantine/index.d.ts",
      "import": "./dist/mantine/index.js"
    },
    "./mantine.css": "./dist/mantine/styles.css",
    "./daisyui": {
      "types": "./dist/daisyui/index.d.ts",
      "import": "./dist/daisyui/index.js"
    },
    "./daisyui.css": "./dist/daisyui/theme.css",
    "./astro/starlight": {
      "types": "./dist/astro/starlight/index.d.ts",
      "import": "./dist/astro/starlight/index.js"
    },
    "./astro/starlight.css": "./dist/astro/starlight/theme.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
