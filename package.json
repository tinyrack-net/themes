{
  "name": "tinyrack-ui-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "biome": "biome check .",
    "dev": "pnpm --filter @tinyrack/homepage dev",
    "build": "pnpm --filter @tinyrack/ui build && pnpm --filter @tinyrack/docs build && pnpm --filter @tinyrack/homepage build",
    "docs:build": "pnpm build",
    "docs:preview": "pnpm docs:build && pnpm --filter @tinyrack/homepage preview",
    "docs:capture": "pnpm --filter @tinyrack/homepage capture",
    "docs:deploy": "pnpm --filter @tinyrack/homepage run deploy",
    "docs:deploy:dry-run": "pnpm --filter @tinyrack/homepage deploy:dry-run",
    "pack:ui": "pnpm --config.ignore-scripts=true --dir packages/ui pack --dry-run",
    "pack:docs": "pnpm --config.ignore-scripts=true --dir packages/docs pack --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2"
  }
}
