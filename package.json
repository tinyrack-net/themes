{
  "name": "@tinyrack/ui",
  "version": "0.1.0",
  "description": "CSS-first Tinyrack UI tokens and components.",
  "keywords": [
    "design-system",
    "storybook",
    "tailwindcss",
    "theme",
    "tokens",
    "typescript",
    "ui"
  ],
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "author": "Tinyrack",
  "homepage": "https://www.npmjs.com/package/@tinyrack/ui",
  "bugs": {
    "url": "https://github.com/tinyrack-net/themes/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tinyrack-net/themes.git"
  },
  "files": [
    "dist/components/button/button.css",
    "dist/components/button/contract.*",
    "dist/components/button/react.*",
    "dist/components/table/table.css",
    "dist/components/table/contract.*",
    "dist/components/table/react.*",
    "dist/core/core.css",
    "dist/core/index.*",
    "dist/core/tokens",
    "README.md"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006 --host 127.0.0.1 --no-open",
    "build": "pnpm build:css",
    "build:types": "node scripts/clean-dist.ts && tsc -p tsconfig.build.json",
    "build:css": "pnpm build:types && node scripts/copy-css.ts",
    "check:css": "node scripts/copy-css.ts --check",
    "check:types": "tsc -p tsconfig.json --noEmit && pnpm check:tests",
    "check:tests": "tsc -p tsconfig.test.json --noEmit",
    "check:scripts": "tsc -p tsconfig.scripts.json",
    "verify": "pnpm biome && pnpm check:types && pnpm check:scripts && pnpm check:css && pnpm test && pnpm check:e2e && pnpm build && pnpm test:dist",
    "verify:release": "pnpm verify && pnpm test:storybook",
    "test": "pnpm test:unit && pnpm test:component",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project browser",
    "test:coverage": "vitest run --project unit --project browser --coverage",
    "test:dist": "node e2e/dist-package-smoke.ts",
    "storybook": "storybook dev -p 6006 --host 127.0.0.1 --no-open",
    "storybook:build": "storybook build",
    "biome": "biome check .",
    "biome:fix": "biome check --write .",
    "test:storybook": "pnpm storybook:build",
    "check:e2e": "vitest run --project e2e",
    "check:stories": "vitest run --project e2e e2e/storybook-structure.test.ts",
    "deploy:storybook": "wrangler deploy",
    "deploy:storybook:dry-run": "wrangler deploy --dry-run",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@storybook/addon-docs": "latest",
    "@storybook/addon-themes": "latest",
    "@storybook/react-vite": "latest",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gfm": "^4.0.1",
    "storybook": "latest",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0",
    "wrangler": "4.107.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./components/button/react": {
      "types": "./dist/components/button/react.d.ts",
      "import": "./dist/components/button/react.js"
    },
    "./components/table/react": {
      "types": "./dist/components/table/react.d.ts",
      "import": "./dist/components/table/react.js"
    },
    "./components/button/button.css": "./dist/components/button/button.css",
    "./components/table/table.css": "./dist/components/table/table.css",
    "./core/core.css": "./dist/core/core.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
